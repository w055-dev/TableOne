# Copy this file to .env and fill in your values
# cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tableone
DB_USER=postgres
DB_PASSWORD=2

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
REFRESH_SECRET=change_this_to_another_long_random_string
ACCESS_EXPIRES=45m
REFRESH_EXPIRES=1d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
